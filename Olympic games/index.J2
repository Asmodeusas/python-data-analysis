<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Reporte Olímpicos</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 40px;
            background: #f5f5f5;
            color: #222;
        }

        h1,
        h2 {
            color: #0b3d91;
        }

        .bloque {
            background: white;
            padding: 20px;
            margin-bottom: 30px;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

        th,
        td {
            border: 1px solid #ccc;
            padding: 8px;
            text-align: left;
        }

        th {
            background: #0b3d91;
            color: white;
        }

        tr:nth-child(even) {
            background: #f2f2f2;
        }

        img {
            max-width: 100%;
            height: auto;
            display: block;
            margin-top: 15px;
            border-radius: 8px;
        }
    </style>
</head>

<body>
    <h1>Reporte de análisis de atletas olímpicos</h1>

    <div class="bloque">
        <h2>Atletas de UK (GBR)</h2>
        <table>
            <thead>
                <tr>
                    {% for col in columnas %}
                    <th>{{ col }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% for fila in tabla_uk %}
                <tr>
                    {% for col in columnas %}
                    <td>{{ fila[col] }}</td>
                    {% endfor %}
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="bloque">
        <h2>Atletas con apellido Watson</h2>
        <table>
            <thead>
                <tr>
                    {% for col in columnas %}
                    <th>{{ col }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% for fila in tabla_watson %}
                <tr>
                    {% for col in columnas %}
                    <td>{{ fila[col] }}</td>
                    {% endfor %}
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="bloque">
        <h2>Atletas más altos</h2>
        <table>
            <thead>
                <tr>
                    {% for col in columnas %}
                    <th>{{ col }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% for fila in tabla_altos %}
                <tr>
                    {% for col in columnas %}
                    <td>{{ fila[col] }}</td>
                    {% endfor %}
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="bloque">
        <h2>Distribución de altura</h2>
        <img src="{{ grafico_alturas }}" alt="Gráfico de alturas">
    </div>

    <div class="bloque">
        <h2>Distribución de atletas por país</h2>
        <img src="{{ grafico_pais }}" alt="Gráfico por país">
    </div>

    <div class="bloque">
        <h2>Atletas de Madrid con menos de 70 kg</h2>
        <table>
            <thead>
                <tr>
                    {% for col in columnas %}
                    <th>{{ col }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% for fila in tabla_madrid %}
                <tr>
                    {% for col in columnas %}
                    <td>{{ fila[col] }}</td>
                    {% endfor %}
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</body>

</html>